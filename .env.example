# Supabase PostgreSQL — Connection pooled (porta 6543) per query a runtime
DATABASE_URL="postgresql://..."

# Supabase PostgreSQL — Connessione diretta (porta 5432) per migrazioni Prisma
DIRECT_URL="postgresql://..."

# NextAuth
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="restaurant-media"

# URL pubblico dell'applicazione (in produzione: https://aifolly-menu.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry — Error tracking
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_AUTH_TOKEN="sntrys_xxx"

# PostHog — Product analytics
NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Resend — Email provider per verifica email signup self-service.
# In dev usare il dominio gratuito "onboarding@resend.dev" (le email arrivano
# solo al proprietario dell'account Resend). In prod serve dominio custom
# verificato con DNS records SPF/DKIM/return-path.
RESEND_API_KEY=""
EMAIL_FROM="AiFolly Menu <onboarding@resend.dev>"

# Google OAuth — credenziali da Google Cloud Console (APIs & Services → Credentials).
# Authorized redirect URIs da configurare: {APP_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
